{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "bun .github/hooks/functional-consistency.ts",
        "linux": "sh .github/hooks/run-bun-hook.sh .github/hooks/functional-consistency.ts",
        "osx": "sh .github/hooks/run-bun-hook.sh .github/hooks/functional-consistency.ts",
        "cwd": ".",
        "timeout": 60
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bun .github/hooks/functional-consistency.ts",
        "linux": "sh .github/hooks/run-bun-hook.sh .github/hooks/functional-consistency.ts",
        "osx": "sh .github/hooks/run-bun-hook.sh .github/hooks/functional-consistency.ts",
        "cwd": ".",
        "timeout": 180
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bun .github/hooks/functional-consistency.ts",
        "linux": "sh .github/hooks/run-bun-hook.sh .github/hooks/functional-consistency.ts",
        "osx": "sh .github/hooks/run-bun-hook.sh .github/hooks/functional-consistency.ts",
        "cwd": ".",
        "timeout": 30
      }
    ]
  }
}