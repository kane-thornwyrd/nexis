{
  "name": "nexis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun ./build-watcher",
    "subbuild:style": "bun run tailwindcss -m -i ./src/main.css -o ./src/index.css",
    "subbuild:bin:linux": "bun build --compile --asset-naming=\"[name].[ext]\" --bytecode --target=bun-linux-x64 ./src/server.ts --outfile bin/linux-x64/nexis",
    "subbuild:bin:linux-arm": "bun build --compile --asset-naming=\"[name].[ext]\" --bytecode --target=bun-linux-arm64 ./src/server.ts --outfile bin/linux-arm64/nexis",
    "subbuild:bin:windows": "bun build --compile --asset-naming=\"[name].[ext]\" --bytecode --target=bun-windows-x64 ./src/server.ts --outfile bin/windows-x64/nexis",
    "subbuild:bin:windows-arm": "bun build --compile --asset-naming=\"[name].[ext]\" --bytecode --target=bun-windows-arm64 ./src/server.ts --outfile bin/windows-arm64/nexis",
    "subbuild:bin:darwin": "bun build --compile --asset-naming=\"[name].[ext]\" --bytecode --target=bun-darwin-x64 ./src/server.ts --outfile bin/darwin-x64/nexis",
    "subbuild:bin:darwin-arm": "bun build --compile --asset-naming=\"[name].[ext]\" --bytecode --target=bun-darwin-arm64 ./src/server.ts --outfile bin/darwin-arm64/nexis",
    "build:bin": "run-p -a -b -k -t subbuild:bin:*",
    "build": "run-s subbuild:style build:bin",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/geist-mono": "5.2.7",
    "@tabler/icons-react": "3.40.0",
    "@tailwindcss/cli": "4.2.1",
    "bun-plugin-tailwind": "0.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "effect": "3.21.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "shadcn": "4.1.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "wouter": "3.9.0"
  },
  "devDependencies": {
    "@effect/language-service": "0.82.0",
    "@types/bun": "1.3.10",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "npm-run-all-next": "1.2.4",
    "prettier-eslint": "16.4.2"
  },
  "serverConfig": {
    "port": 8888
  }
}
